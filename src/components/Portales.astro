---

<section class="w-full bg-white py-[80px] px-6 md:px-[80px]">
  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="inline-block font-[Montserrat] text-[12px] font-semibold text-[#4CAF7A] tracking-widest uppercase mb-3"
      >
        Recursos oficiales
      </span>
      <h2
        class="font-[Montserrat] text-[28px] md:text-[38px] font-bold text-[#1E293B] leading-tight mb-4"
      >
        Portales del gobierno
      </h2>
      <p class="text-[#64748B] text-base md:text-lg max-w-2xl mx-auto">
        Accede directamente a los portales oficiales que necesitas para tus trámites fiscales, laborales y financieros.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {portals.map((p) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-[#F8FAFC] border border-[#E2E8F0] rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:border-[#CBD5E1] hover:-translate-y-1"
        >
          <!-- Top row: icon + external link -->
          <div class="flex items-center justify-between mb-4">
            <div
              class="w-12 h-12 rounded-lg flex items-center justify-center"
              style={`background: ${p.bg};`}
            >
              <Fragment set:html={p.icon} />
            </div>
            <svg
              class="w-4 h-4 text-[#94A3B8] group-hover:text-[#64748B] transition-colors"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </div>

          <!-- Name badge -->
          <span
            class="inline-block text-[13px] font-semibold font-[Montserrat] rounded-md px-3 py-1 mb-3"
            style={`background: ${p.bg}; color: ${p.color};`}
          >
            {p.name}
          </span>

          <!-- Description -->
          <p class="text-[#475569] text-[13px] leading-relaxed mb-3">
            {p.desc}
          </p>

          <!-- URL -->
          <span class="text-[#94A3B8] text-[12px] font-medium">
            {p.url}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
