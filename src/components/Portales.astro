---

<section class="w-full bg-white py-16 md:py-[80px] px-6 md:px-16 lg:px-[80px]">
  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="inline-block font-heading text-[12px] font-semibold text-verde tracking-widest uppercase mb-3"
      >
        Recursos oficiales
      </span>
      <h2
        class="font-heading text-[28px] md:text-[38px] font-bold text-azul leading-tight mb-4"
      >
        Portales del gobierno
      </h2>
      <p class="text-gris text-base md:text-lg max-w-2xl mx-auto">
        Acceso directo a las plataformas oficiales que m&aacute;s utilizan las empresas en M&eacute;xico.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5" id="portals-grid">
      {portals.map((p, index) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`portal-card group block bg-bg border border-border rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:border-[#CBD5E1] hover:-translate-y-1 ${index >= 4 ? 'hidden md:block' : ''}`}
        >
          <!-- Top row: icon + external link -->
          <div class="flex items-center justify-between mb-4">
            <div
              class="w-12 h-12 rounded-lg flex items-center justify-center"
              style={`background: ${p.bg};`}
            >
              <Fragment set:html={p.icon} />
            </div>
            <svg
              class="w-4 h-4 text-gris-light group-hover:text-gris transition-colors"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </div>

          <!-- Name badge -->
          <span
            class="inline-block text-[13px] font-semibold font-heading rounded-md px-3 py-1 mb-3"
            style={`background: ${p.bg}; color: ${p.color};`}
          >
            {p.name}
          </span>

          <!-- Description -->
          <p class="text-[#475569] text-[13px] leading-relaxed mb-3">
            {p.desc}
          </p>

          <!-- URL -->
          <span class="text-gris-light text-[12px] font-medium truncate block max-w-full">
            {p.url}
          </span>
        </a>
      ))}
    </div>

    <!-- Mostrar más (Mobile only) -->
    <div class="mt-8 text-center md:hidden" id="show-more-container">
      <button id="show-more-btn" class="inline-flex items-center gap-2 bg-white border border-border text-azul font-heading font-semibold text-[14px] px-6 py-3 rounded-full hover:bg-bg transition-colors cursor-pointer">
        <span id="show-more-text">Mostrar más portales</span>
        <svg id="show-more-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const showMoreBtn = document.getElementById('show-more-btn');
    const btnText = document.getElementById('show-more-text');
    const btnIcon = document.getElementById('show-more-icon');
    const grid = document.getElementById('portals-grid');
    const cards = document.querySelectorAll('.portal-card');
    let isExpanded = false;

    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', () => {
        isExpanded = !isExpanded;
        
        if (isExpanded) {
          // Show all
          cards.forEach((card, index) => {
            if (index >= 4) card.classList.remove('hidden');
          });
          if (btnText) btnText.textContent = "Mostrar menos portales";
          if (btnIcon) btnIcon.innerHTML = '<path d="m18 15-6-6-6 6"/>';
        } else {
          // Hide
          cards.forEach((card, index) => {
            if (index >= 4) {
              card.classList.add('hidden');
              // Ensure it still has md:block for desktop resizing
              if (!card.classList.contains('md:block')) card.classList.add('md:block');
            }
          });
          if (btnText) btnText.textContent = "Mostrar más portales";
          if (btnIcon) btnIcon.innerHTML = '<path d="m6 9 6 6 6-6"/>';
          
          // Maintain scroll position smoothly so user isn't lost
          if (grid) {
            const y = grid.getBoundingClientRect().top + window.scrollY - 100;
            window.scrollTo({ top: y, behavior: 'smooth' });
          }
        }
      });
    }
  });
</script>
