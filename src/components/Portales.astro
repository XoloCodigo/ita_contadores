    bg: "#FEF2F2",
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="#B91C1C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-6h6v6"/></svg>`,
  },
  {
    name: "IMSS",
    desc: "Instituto Mexicano del Seguro Social. Altas, bajas y movimientos de empleados.",
    url: "imss.gob.mx",
    href: "https://www.imss.gob.mx",
    color: "#047857",
    bg: "#ECFDF5",
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="#047857" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
