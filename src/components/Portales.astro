  {
    name: "BANXICO",
    desc: "Banco de México. Tipos de cambio, indicadores económicos y política monetaria.",
    url: "banxico.org.mx",
    href: "https://www.banxico.org.mx",
    color: "#059669",
    bg: "#ECFDF5",
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>`,
