---
// Calculadora section - ITA Contadores
---

<section id="calculadora" class="reveal w-full bg-bg py-20 px-6 lg:px-20">
  <div class="max-w-7xl mx-auto">

    <!-- Two-column layout -->
    <div class="flex flex-col lg:flex-row items-start gap-12 lg:gap-16">

      <!-- Left side: Text content -->
      <div class="flex-1 flex flex-col justify-center">
        <span class="inline-block text-verde text-xs font-heading font-bold tracking-[0.15em] uppercase mb-3">
          Herramienta gratuita
        </span>
        <h2 class="text-azul text-[28px] md:text-[36px] font-heading font-bold leading-tight mb-5">
          &iquest;Cu&aacute;nto pagar&iacute;as de impuestos?
        </h2>
        <p class="text-gris text-[15px] font-body leading-relaxed mb-8 max-w-lg">
          Usa nuestra calculadora fiscal b&aacute;sica para tener una estimaci&oacute;n r&aacute;pida. Para un an&aacute;lisis detallado y personalizado, agenda una asesor&iacute;a con nuestro equipo.
        </p>

        <!-- Tip box -->
        <div class="bg-verde/10 border border-verde/20 rounded-xl px-5 py-4 flex items-start gap-3 max-w-lg">
          <div class="w-9 h-9 rounded-lg bg-verde/20 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-verde" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"></rect>
              <path d="M3 9h18"></path>
              <path d="M9 21V9"></path>
            </svg>
          </div>
          <p class="text-[14px] font-body text-azul leading-relaxed">
            <strong>&iquest;Sab&iacute;as qu&eacute;?</strong> Muchas empresas pagan m&aacute;s impuestos de los que deben por falta de estrategia fiscal.
          </p>
        </div>
      </div>

      <!-- Right side: Form card -->
      <div class="w-full lg:w-[420px] shrink-0">
        <div class="bg-white border border-border rounded-2xl p-8 shadow-sm">
          <h4 class="text-azul text-lg font-heading font-bold mb-6" id="calculadora-form">
            Calculadora fiscal estimada
          </h4>

          <form id="calc-form" class="flex flex-col gap-5">
            <!-- Ingresos mensuales -->
            <div class="flex flex-col gap-2">
              <label for="ingresos" class="text-azul text-[14px] font-heading font-semibold">
                Ingresos mensuales
              </label>
              <input
                type="number"
                id="ingresos"
                name="ingresos"
                placeholder="Ej: 50000"
                min="0"
                class="w-full bg-white border border-border rounded-xl px-4 py-3.5 text-[15px] text-azul font-body placeholder:text-gris-light focus:outline-none focus:ring-2 focus:ring-verde/30 focus:border-verde transition-colors"
              />
            </div>

            <!-- Régimen fiscal -->
            <div class="flex flex-col gap-2">
              <label for="regimen" class="text-azul text-[14px] font-heading font-semibold">
                R&eacute;gimen fiscal
              </label>
              <select
                id="regimen"
                name="regimen"
                class="w-full bg-white border border-border rounded-xl px-4 py-3.5 text-[15px] text-azul font-body focus:outline-none focus:ring-2 focus:ring-verde/30 focus:border-verde transition-colors appearance-none"
              >
                <option value="" disabled selected>Selecciona tu r&eacute;gimen</option>
                <option value="fisica">Persona F&iacute;sica</option>
                <option value="moral">Persona Moral</option>
                <option value="resico">RESICO</option>
                <option value="arrendamiento">Arrendamiento</option>
                <option value="actividad_empresarial">Actividad Empresarial</option>
              </select>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full bg-azul text-white font-heading font-semibold text-[15px] rounded-xl px-6 py-4 hover:bg-azul-light transition-colors cursor-pointer flex items-center justify-center gap-2"
            >
              Calculadora &rarr;
            </button>
          </form>

          <!-- Result -->
          <div id="calc-result" class="hidden bg-verde/5 border border-verde/20 rounded-xl p-5 mt-5">
            <p class="text-gris text-[13px] font-body mb-1">Impuesto estimado mensual:</p>
            <p id="calc-amount" class="text-azul text-2xl font-heading font-bold"></p>
            <p class="text-gris-light text-[11px] font-body mt-2">
              *Estimaci&oacute;n simplificada. Consulta a un experto para un c&aacute;lculo exacto.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('calc-form') as HTMLFormElement;
  const resultDiv = document.getElementById('calc-result') as HTMLDivElement;
  const amountEl = document.getElementById('calc-amount') as HTMLParagraphElement;

  form?.addEventListener('submit', (e: Event) => {
    e.preventDefault();

    const ingresos = parseFloat((document.getElementById('ingresos') as HTMLInputElement).value) || 0;
    const regimen = (document.getElementById('regimen') as HTMLSelectElement).value;

    if (ingresos <= 0 || !regimen) return;

    let tasa = 0;

    switch (regimen) {
      case 'fisica':
        if (ingresos <= 7735) tasa = 0.0192;
        else if (ingresos <= 21321) tasa = 0.0640;
        else if (ingresos <= 42537) tasa = 0.1088;
        else if (ingresos <= 83333) tasa = 0.16;
        else tasa = 0.2136;
        break;
      case 'moral':
        tasa = 0.30;
        break;
      case 'resico':
        if (ingresos <= 25000) tasa = 0.01;
        else if (ingresos <= 50000) tasa = 0.011;
        else if (ingresos <= 83333) tasa = 0.015;
        else tasa = 0.02;
        break;
      case 'arrendamiento':
        tasa = 0.35 * 0.30;
        break;
      case 'actividad_empresarial':
        if (ingresos <= 42537) tasa = 0.1088;
        else if (ingresos <= 83333) tasa = 0.16;
        else tasa = 0.2136;
        break;
      default:
        tasa = 0.15;
    }

    const impuesto = ingresos * tasa;

    amountEl.textContent = `$${impuesto.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} MXN`;
    resultDiv.classList.remove('hidden');
  });
</script>
