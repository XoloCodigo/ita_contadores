---
// Hero section - ITA Contadores
---

<section
  id="hero"
  class="relative w-full min-h-[520px] md:min-h-[620px] flex items-center overflow-hidden bg-linear-to-br from-azul to-azul-light"
>
  <!-- Background image with overlay — uses optimized WebP with JPG fallback -->
  <div class="absolute inset-0 opacity-35">
    <picture>
      <source srcset="/images/hero.webp" type="image/webp" />
      <img
        src="/images/hero-opt.jpg"
        alt=""
        role="presentation"
        width="1280"
        height="853"
        fetchpriority="high"
        decoding="sync"
        class="w-full h-full object-cover object-bottom"
      />
    </picture>
  </div>
  <div class="absolute inset-0 bg-linear-to-br from-azul/90 to-azul-light/80"></div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pt-[120px] pb-16 flex flex-col lg:flex-row items-center gap-12">

    <!-- Left side -->
    <div class="flex-1 lg:max-w-[60%]">

      <!-- Title -->
      <h1 class="text-white text-4xl md:text-[48px] font-heading font-bold leading-[1.15] mb-6">
        Impulsamos el <span class="text-verde">crecimiento financiero</span> de tu empresa.
      </h1>

      <!-- Subtitle -->
      <p class="text-white/70 text-lg font-body max-w-xl mb-10">
        Más que contabilidad: estrategia fiscal, cumplimiento y visión a futuro para tu negocio.
      </p>

      <!-- Buttons -->
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="#contacto"
          class="inline-flex items-center bg-verde text-white font-heading font-semibold text-sm rounded-full px-8 py-4 hover:bg-verde/90 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-verde focus-visible:ring-offset-2 focus-visible:ring-offset-azul"
        >
          Agenda Asesoría Gratis &rarr;
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 border border-white/40 text-white font-heading font-semibold text-sm rounded-full px-8 py-4 hover:bg-white/10 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white/60 focus-visible:ring-offset-2 focus-visible:ring-offset-azul"
        >
          <!-- message-circle icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
          Contáctanos
        </a>
      </div>
    </div>

    <!-- Right side - Glass card (hidden on mobile) -->
    <div class="hidden lg:block w-[380px] shrink-0">
      <div id="hero-glass-card" class="bg-white/[0.3] border border-white/[0.2] rounded-2xl p-8 backdrop-blur-md relative min-h-[360px] flex flex-col justify-center overflow-hidden transition-all duration-1000">
        
        <!-- Animated Logo Layer -->
        <div id="hero-animated-logo" class="absolute inset-0 flex items-center justify-center transition-opacity duration-1000 opacity-100 z-10 px-8">
          <img src="/images/logo-opt.webp" alt="ITA Logotipo" width="240" height="240" class="w-full max-w-[240px] h-auto object-contain drop-shadow-2xl" />
        </div>

        <!-- Info List Layer -->
        <div id="hero-info-list" class="flex flex-col gap-6 transition-all duration-1000 opacity-0 translate-y-6 pointer-events-none">

          <!-- Item 1: Estrategia Fiscal -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-verde/20 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-verde" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white font-heading font-semibold text-base mb-1">Estrategia Fiscal</h3>
              <p class="text-white/70 text-sm leading-relaxed">Planeación inteligente para optimizar tus impuestos.</p>
            </div>
          </div>

          <!-- Item 2: Cumplimiento -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-azul-medio/30 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-azul-medio" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <polyline points="9 12 11 14 15 10"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white font-heading font-semibold text-base mb-1">Cumplimiento</h3>
              <p class="text-white/70 text-sm leading-relaxed">Siempre al día con tus obligaciones fiscales.</p>
            </div>
          </div>

          <!-- Item 3: Crecimiento -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-amarillo/20 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amarillo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white font-heading font-semibold text-base mb-1">Crecimiento</h3>
              <p class="text-white/70 text-sm leading-relaxed">Impulsamos tu empresa hacia nuevas metas.</p>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Wait 2 seconds, fade out logo, fade in info list
  setTimeout(() => {
    const heroLogo = document.getElementById('hero-animated-logo');
    const heroInfo = document.getElementById('hero-info-list');
    
    if (heroLogo && heroInfo) {
      heroLogo.classList.remove('opacity-100');
      heroLogo.classList.add('opacity-0');
      
      const heroGlassCard = document.getElementById('hero-glass-card');
      if (heroGlassCard) {
        heroGlassCard.classList.remove('bg-white/[0.3]', 'border-white/[0.2]', 'backdrop-blur-md');
        heroGlassCard.classList.add('bg-white/[0.07]', 'border-white/[0.09]', 'backdrop-blur-sm');
      }

      // After fade out completes
      setTimeout(() => {
        heroLogo.classList.add('hidden');
        heroInfo.classList.remove('pointer-events-none', 'opacity-0', 'translate-y-6');
        heroInfo.classList.add('opacity-100', 'translate-y-0');
      }, 1000); 
    }
  }, 2000);
</script>
