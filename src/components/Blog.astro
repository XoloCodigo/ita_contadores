---
// Blog section - ITA Contadores

const articles = [
  {
    category: "Fiscal",
    title: "Errores comunes en facturación que te pueden multar",
    description: "Descubre los errores más frecuentes al emitir facturas electrónicas y cómo evitar sanciones del SAT que pueden afectar tu negocio.",
    time: 4,
    gradient: "from-azul/60 to-azul-light/40",
  },
  {
    category: "Estrategia",
    title: "Materialidad de las operaciones fiscales",
    description: "Entiende qué es la materialidad fiscal y por qué el SAT la utiliza para verificar que tus operaciones sean reales y comprobables.",
    time: 5,
    gradient: "from-azul-light/50 to-verde/30",
  },
  {
    category: "Contabilidad",
    title: "Tu empresa necesita estados financieros 2026",
    description: "Los estados financieros no solo son un requisito legal, son la brújula que guía las decisiones estratégicas de tu empresa.",
    time: 3,
    gradient: "from-verde/40 to-azul/50",
  },
];
---

<section id="blog" class="w-full bg-white py-20 px-6 lg:px-20">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-verde text-xs font-heading font-bold tracking-[0.15em] uppercase mb-3">
        Blog
      </span>
      <h2 class="text-azul text-[32px] md:text-[38px] font-heading font-bold italic leading-tight mb-4">
        Consejos para tu negocio
      </h2>
      <p class="text-gris text-base font-body max-w-lg mx-auto">
        Artículos prácticos sobre contabilidad, impuestos y estrategia financiera para hacer crecer tu empresa.
      </p>
    </div>

    <!-- Articles grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

      {articles.map((article) => (
        <article class="bg-white border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">

          {/* Image placeholder */}
          <div class={`relative h-[200px] bg-gray-200 bg-gradient-to-br ${article.gradient}`}>
            {/* Category badge */}
            <span class="absolute top-4 left-4 bg-azul text-white text-[11px] font-heading font-semibold tracking-wide uppercase px-3 py-1.5 rounded-lg">
              {article.category}
            </span>
            {/* Decorative elements */}
            <div class="absolute inset-0 flex items-center justify-center opacity-20">
              <svg class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
          </div>

          {/* Content */}
          <div class="flex flex-col flex-1 p-6">
            {/* Reading time */}
            <div class="flex items-center gap-1.5 mb-3">
              {/* clock icon */}
              <svg class="w-3.5 h-3.5 text-gris-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-gris-light text-[12px] font-body">
                {article.time} min de lectura
              </span>
            </div>

            {/* Title */}
            <h3 class="text-azul text-[17px] font-heading font-bold leading-snug mb-2">
              {article.title}
            </h3>

            {/* Description */}
            <p class="text-gris text-[13px] font-body leading-relaxed mb-4 flex-1">
              {article.description}
            </p>

            {/* Read more link */}
            <a href="#" class="inline-flex items-center gap-1 text-verde text-[13px] font-heading font-semibold hover:underline transition-colors">
              Leer más
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

        </article>
      ))}

    </div>

  </div>
</section>
