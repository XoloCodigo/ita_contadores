---
// Navbar.astro – ITA Contadores sticky navbar
---

<header
  id="navbar"
  class="fixed top-0 left-0 w-full z-50 bg-white/10 backdrop-blur-md transition-all duration-300 border-b border-white/20"
>
  <nav
    class="flex items-center justify-between h-[80px] px-6 lg:px-20 max-w-[1440px] mx-auto"
  >
    <!-- Left Group -->
    <div class="flex items-center gap-4 lg:gap-12 w-full lg:w-auto">
      <!-- Logo -->
      <a
        href="/#hero"
        id="navbar-logo-container"
        class="shrink-0 flex items-center translate-y-[14px] max-lg:opacity-100 lg:opacity-0 transition-opacity duration-1000 ease-in-out"
      >
        <img
          id="navbar-logo"
          src="/images/logo-navbar-white.webp"
          alt="ITA Contadores"
          width="280"
          height="50"
          class="min-w-[200px] md:min-w-[240px] lg:min-w-[280px] w-[200px] md:w-[240px] lg:w-[280px] h-auto object-contain block"
        />
      </a>

      <!-- Desktop Nav Links -->
      <ul
        class="hidden lg:flex items-center gap-8 font-heading text-[15px] font-medium transition-all duration-1000"
      >
        <li>
          <a
            href="/#hero"
            class="nav-link text-white hover:text-verde transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-verde rounded"
          >
            Inicio
          </a>
        </li>
        <li>
          <a
            href="/#servicios"
            class="nav-link text-white hover:text-verde transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-verde rounded"
          >
            Servicios
          </a>
        </li>
        <li>
          <a
            href="/#nosotros"
            class="nav-link text-white hover:text-verde transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-verde rounded"
          >
            Nosotros
          </a>
        </li>
        <li>
          <a
            href="/#blog"
            class="nav-link text-white hover:text-verde transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-verde rounded"
          >
            Blog
          </a>
        </li>
        <li>
          <a
            href="/#contacto"
            class="nav-link text-white hover:text-verde transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-verde rounded"
          >
            Contacto
          </a>
        </li>
      </ul>
    </div>

    <!-- Desktop CTA Button -->
    <a
      href="/#contacto"
      class="hidden lg:inline-flex items-center gap-2 bg-verde text-white font-heading text-[14px] font-semibold rounded-full px-5 py-2.5 whitespace-nowrap shrink-0 hover:bg-verde/90 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-verde focus-visible:ring-offset-2"
    >
      <!-- Lucide Phone icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
        ></path>
      </svg>
      Agenda Asesor&iacute;a
    </a>

    <!-- Mobile Hamburger Button -->
    <button
      id="menu-toggle"
      class="lg:hidden flex items-center justify-center w-10 h-10 text-white cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-verde rounded-lg"
      aria-label="Abrir menú"
    >
      <!-- Lucide Menu icon -->
      <svg
        id="icon-menu"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
      <!-- Lucide X icon (hidden by default) -->
      <svg
        id="icon-close"
        class="hidden"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white border-t border-gray-100 px-6 pb-6"
  >
    <ul class="flex flex-col gap-4 pt-4 font-heading text-[15px] font-medium">
      <li>
        <a
          href="/#hero"
          class="block text-verde hover:text-verde transition-colors"
        >
          Inicio
        </a>
      </li>
      <li>
        <a
          href="/#servicios"
          class="block text-[#4B5563] hover:text-verde transition-colors"
        >
          Servicios
        </a>
      </li>
      <li>
        <a
          href="/#nosotros"
          class="block text-[#4B5563] hover:text-verde transition-colors"
        >
          Nosotros
        </a>
      </li>
      <li>
        <a
          href="/#blog"
          class="block text-[#4B5563] hover:text-verde transition-colors"
        >
          Blog
        </a>
      </li>
      <li>
        <a
          href="/#contacto"
          class="block text-[#4B5563] hover:text-verde transition-colors"
        >
          Contacto
        </a>
      </li>
    </ul>
    <a
      href="/#contacto"
      class="inline-flex items-center gap-2 mt-4 bg-verde text-white font-heading text-[15px] font-semibold rounded-full px-6 py-3 hover:bg-verde/90 transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
        ></path>
      </svg>
      Agenda Asesor&iacute;a
    </a>
  </div>
</header>

<script>
  // Navbar: transparent on hero, white after scroll
  const navbar = document.getElementById("navbar");
  const hero = document.getElementById("hero");
  const navLinks = document.querySelectorAll(".nav-link");
  const menuBtn = document.getElementById("menu-toggle");

  function updateNavbar() {
    const heroBottom = hero ? hero.offsetHeight - 80 : 500;
    const scrolled = window.scrollY > heroBottom;

    if (scrolled) {
      navbar?.classList.remove("bg-white/10");
      navbar?.classList.add("bg-white/85", "shadow-md");
      const logo = document.getElementById("navbar-logo") as HTMLImageElement;
      if (logo) logo.src = "/images/logo-navbar-dark.webp";
      navLinks.forEach((link) => {
        link.classList.remove("text-white");
        link.classList.add("text-[#4B5563]");
      });
      menuBtn?.classList.remove("text-white");
      menuBtn?.classList.add("text-[#4B5563]");
    } else {
      navbar?.classList.remove("bg-white/85", "shadow-md");
      navbar?.classList.add("bg-white/10");
      const logo = document.getElementById("navbar-logo") as HTMLImageElement;
      if (logo) logo.src = "/images/logo-navbar-white.webp";
      navLinks.forEach((link) => {
        link.classList.remove("text-[#4B5563]");
        link.classList.add("text-white");
      });
      menuBtn?.classList.remove("text-[#4B5563]");
      menuBtn?.classList.add("text-white");
    }
  }

  window.addEventListener("scroll", updateNavbar);
  updateNavbar();

  // Sync logo animation on load — starts 0.5s before hero logo fades out for smooth overlap
  setTimeout(() => {
    const logoContainer = document.getElementById("navbar-logo-container");
    if (logoContainer) {
      logoContainer.classList.remove("lg:opacity-0");
    }
  }, 1500);

  // Mobile menu toggle
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  menuToggle?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    iconMenu?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    menuToggle.setAttribute(
      "aria-label",
      isOpen ? "Abrir menú" : "Cerrar menú",
    );
  });

  // Close mobile menu when a link is clicked
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      menuToggle?.setAttribute("aria-label", "Abrir menú");
    });
  });
</script>
