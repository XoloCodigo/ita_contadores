---
// Contacto.astro – Contact section with info + form
---

<section id="contacto" class="w-full bg-white py-[80px] px-6 md:px-[80px]">
  <div class="max-w-[1440px] mx-auto flex flex-col lg:flex-row gap-12 lg:gap-20">

    <!-- Left: Info -->
    <div class="flex-1 lg:max-w-[45%]">
      <span
        class="inline-block font-[Montserrat] text-[12px] font-semibold text-[#4CAF7A] tracking-widest uppercase mb-3"
      >
        Contacto
      </span>
      <h2
        class="font-[Montserrat] text-[28px] md:text-[32px] font-bold text-[#1E293B] leading-tight mb-4"
      >
        Hablemos de tu empresa
      </h2>
      <p class="text-[#64748B] text-base leading-relaxed mb-10 max-w-md">
        Estamos listos para escucharte. Cuéntanos sobre tu negocio y juntos encontraremos la mejor estrategia fiscal y contable para ti.
      </p>

      <!-- Info items -->
      <div class="flex flex-col gap-6">
        <!-- MapPin -->
        <div class="flex items-start gap-4">
          <div class="w-11 h-11 rounded-lg bg-[#F0FDF4] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <p class="text-[#1E293B] text-[14px] font-semibold font-[Montserrat] mb-0.5">Dirección</p>
            <p class="text-[#64748B] text-[14px] leading-relaxed">Hornillos #5, Col. Santa Cecilia,<br/>Tlalnepantla 54130</p>
          </div>
        </div>

        <!-- Mail -->
        <div class="flex items-start gap-4">
          <div class="w-11 h-11 rounded-lg bg-[#F0FDF4] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="text-[#1E293B] text-[14px] font-semibold font-[Montserrat] mb-0.5">Correo electrónico</p>
            <p class="text-[#64748B] text-[14px]">mtrujillo@itacontadores.com</p>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex items-start gap-4">
          <div class="w-11 h-11 rounded-lg bg-[#F0FDF4] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="text-[#1E293B] text-[14px] font-semibold font-[Montserrat] mb-0.5">Teléfono</p>
            <p class="text-[#64748B] text-[14px]">55 59 20 23 11</p>
          </div>
        </div>

        <!-- Clock -->
        <div class="flex items-start gap-4">
          <div class="w-11 h-11 rounded-lg bg-[#F0FDF4] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="text-[#1E293B] text-[14px] font-semibold font-[Montserrat] mb-0.5">Horario de atención</p>
            <p class="text-[#64748B] text-[14px]">Lunes a Viernes, 9:00 AM - 6:00 PM</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Form -->
    <div class="flex-1">
      <form class="bg-[#F8FAFC] border border-[#E2E8F0] rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <!-- Nombre -->
          <div class="flex flex-col gap-1.5">
            <label for="nombre" class="text-[#1E293B] text-[13px] font-semibold font-[Montserrat]">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              placeholder="Tu nombre completo"
              class="w-full bg-white border border-[#E2E8F0] rounded-xl px-4 py-3 text-[14px] text-[#1E293B] placeholder:text-[#94A3B8] outline-none focus:border-[#4CAF7A] focus:ring-1 focus:ring-[#4CAF7A] transition-colors"
            />
          </div>

          <!-- Teléfono -->
          <div class="flex flex-col gap-1.5">
            <label for="telefono" class="text-[#1E293B] text-[13px] font-semibold font-[Montserrat]">Teléfono</label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              placeholder="55 1234 5678"
              class="w-full bg-white border border-[#E2E8F0] rounded-xl px-4 py-3 text-[14px] text-[#1E293B] placeholder:text-[#94A3B8] outline-none focus:border-[#4CAF7A] focus:ring-1 focus:ring-[#4CAF7A] transition-colors"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <!-- Correo -->
          <div class="flex flex-col gap-1.5">
            <label for="correo" class="text-[#1E293B] text-[13px] font-semibold font-[Montserrat]">Correo</label>
            <input
              type="email"
              id="correo"
              name="correo"
              placeholder="tu@empresa.com"
              class="w-full bg-white border border-[#E2E8F0] rounded-xl px-4 py-3 text-[14px] text-[#1E293B] placeholder:text-[#94A3B8] outline-none focus:border-[#4CAF7A] focus:ring-1 focus:ring-[#4CAF7A] transition-colors"
            />
          </div>

          <!-- Empresa -->
          <div class="flex flex-col gap-1.5">
            <label for="empresa" class="text-[#1E293B] text-[13px] font-semibold font-[Montserrat]">Empresa</label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              placeholder="Nombre de tu empresa"
              class="w-full bg-white border border-[#E2E8F0] rounded-xl px-4 py-3 text-[14px] text-[#1E293B] placeholder:text-[#94A3B8] outline-none focus:border-[#4CAF7A] focus:ring-1 focus:ring-[#4CAF7A] transition-colors"
            />
          </div>
        </div>

        <!-- Mensaje -->
        <div class="flex flex-col gap-1.5 mb-6">
          <label for="mensaje" class="text-[#1E293B] text-[13px] font-semibold font-[Montserrat]">Mensaje</label>
          <textarea
            id="mensaje"
            name="mensaje"
            rows="4"
            placeholder="Cuéntanos cómo podemos ayudarte..."
            class="w-full bg-white border border-[#E2E8F0] rounded-xl px-4 py-3 text-[14px] text-[#1E293B] placeholder:text-[#94A3B8] outline-none focus:border-[#4CAF7A] focus:ring-1 focus:ring-[#4CAF7A] transition-colors resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full bg-[#2B2A5A] hover:bg-[#363473] text-white font-[Montserrat] font-semibold text-[15px] py-3.5 rounded-xl transition-colors duration-300 flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
          Enviar Mensaje
        </button>
      </form>
    </div>

  </div>
</section>
