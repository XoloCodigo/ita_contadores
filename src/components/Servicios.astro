---
// Servicios.astro – ITA Contadores services section with tabs
---

<section id="servicios" class="bg-[#F8FAFC] py-20 px-6 lg:px-20">
  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="inline-block font-[Montserrat] text-[12px] font-semibold text-[#4CAF7A] tracking-widest uppercase mb-3"
      >
        SERVICIOS
      </span>
      <h2 class="font-[Montserrat] text-[28px] md:text-[38px] font-bold italic text-[#2B2A5A] leading-tight mb-4">
        Soluciones integrales para tu negocio
      </h2>
      <p class="font-['Open_Sans'] text-[16px] text-[#64748B] max-w-2xl mx-auto">
        Ofrecemos un ecosistema completo de servicios dise&ntilde;ados para impulsar el crecimiento y la estabilidad de tu empresa.
      </p>
    </div>

    <!-- Tabs + Content -->
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Left: Tab buttons -->
      <div class="flex flex-col gap-3 w-full lg:w-[380px] shrink-0">
        <!-- Tab 0: Fiscal -->
        <button
          data-tab="0"
          class="srv-tab srv-tab-active flex items-center gap-4 w-full rounded-2xl p-5 text-left transition-all duration-200 border bg-[#2B2A5A] border-[#2B2A5A]"
        >
          <div class="w-[48px] h-[48px] rounded-xl flex items-center justify-center shrink-0 bg-[#3D3C6E]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"></path>
              <path d="M13 5v2"></path>
              <path d="M13 17v2"></path>
              <path d="M13 11v2"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-[Montserrat] text-[16px] font-bold text-white">Fiscal</h3>
            <p class="font-['Open_Sans'] text-[13px] text-white/70">4 servicios disponibles</p>
          </div>
        </button>

        <!-- Tab 1: Contabilidad -->
        <button
          data-tab="1"
          class="srv-tab flex items-center gap-4 w-full rounded-2xl p-5 text-left transition-all duration-200 border bg-white border-[#E2E8F0]"
        >
          <div class="w-[48px] h-[48px] rounded-xl flex items-center justify-center shrink-0 bg-[#FEF3C7]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"></path>
              <path d="M14 8H8"></path>
              <path d="M16 12H8"></path>
              <path d="M13 16H8"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-[Montserrat] text-[16px] font-bold text-[#2B2A5A]">Contabilidad</h3>
            <p class="font-['Open_Sans'] text-[13px] text-[#64748B]">4 servicios disponibles</p>
          </div>
        </button>

        <!-- Tab 2: Administrativo -->
        <button
          data-tab="2"
          class="srv-tab flex items-center gap-4 w-full rounded-2xl p-5 text-left transition-all duration-200 border bg-white border-[#E2E8F0]"
        >
          <div class="w-[48px] h-[48px] rounded-xl flex items-center justify-center shrink-0 bg-[#DBEAFE]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"></rect>
              <path d="M3 9h18"></path>
              <path d="M9 21V9"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-[Montserrat] text-[16px] font-bold text-[#2B2A5A]">Administrativo</h3>
            <p class="font-['Open_Sans'] text-[13px] text-[#64748B]">4 servicios disponibles</p>
          </div>
        </button>

        <!-- Tab 3: Alianzas -->
        <button
          data-tab="3"
          class="srv-tab flex items-center gap-4 w-full rounded-2xl p-5 text-left transition-all duration-200 border bg-white border-[#E2E8F0]"
        >
          <div class="w-[48px] h-[48px] rounded-xl flex items-center justify-center shrink-0 bg-[#F3E8FF]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m11 17 2 2a1 1 0 1 0 3-3"></path>
              <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"></path>
              <path d="m21 3 1 11h-2"></path>
              <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"></path>
              <path d="M3 4h8"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-[Montserrat] text-[16px] font-bold text-[#2B2A5A]">Alianzas</h3>
            <p class="font-['Open_Sans'] text-[13px] text-[#64748B]">4 servicios disponibles</p>
          </div>
        </button>
      </div>

      <!-- Right: Content panels -->
      <div class="flex-1 min-w-0">
        <!-- Panel 0: Fiscal -->
        <div data-panel="0" class="srv-panel">
          <div class="bg-white rounded-2xl border border-[#E2E8F0] p-8 lg:p-10">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-[52px] h-[52px] rounded-xl flex items-center justify-center bg-[#EEEEF5]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2B2A5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"></path>
                  <path d="M13 5v2"></path>
                  <path d="M13 17v2"></path>
                  <path d="M13 11v2"></path>
                </svg>
              </div>
              <h3 class="font-[Montserrat] text-[22px] font-bold text-[#2B2A5A]">Servicios Fiscales</h3>
            </div>
            <p class="font-['Open_Sans'] text-[15px] text-[#64748B] leading-relaxed mb-8">
              Te ayudamos a cumplir con todas tus obligaciones tributarias de forma eficiente, evitando multas y recargos. Nuestro equipo se mantiene actualizado con los cambios en la legislaci&oacute;n fiscal.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Declaraciones mensuales y anuales</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Planeaci&oacute;n fiscal estrat&eacute;gica</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Auditor&iacute;as y dict&aacute;menes</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Defensa fiscal ante el SAT</span>
              </div>
            </div>
            <a href="#contacto" class="inline-flex items-center gap-2 font-[Montserrat] text-[14px] font-semibold text-[#4CAF7A] hover:text-[#3d9466] transition-colors">
              Solicitar informaci&oacute;n
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        </div>

        <!-- Panel 1: Contabilidad -->
        <div data-panel="1" class="srv-panel hidden">
          <div class="bg-white rounded-2xl border border-[#E2E8F0] p-8 lg:p-10">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-[52px] h-[52px] rounded-xl flex items-center justify-center bg-[#FEF3C7]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"></path>
                  <path d="M14 8H8"></path>
                  <path d="M16 12H8"></path>
                  <path d="M13 16H8"></path>
                </svg>
              </div>
              <h3 class="font-[Montserrat] text-[22px] font-bold text-[#2B2A5A]">Servicios de Contabilidad</h3>
            </div>
            <p class="font-['Open_Sans'] text-[15px] text-[#64748B] leading-relaxed mb-8">
              Llevamos el registro puntual de todas tus operaciones financieras, generando informaci&oacute;n confiable para la toma de decisiones estrat&eacute;gicas de tu negocio.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Contabilidad general</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Estados financieros</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Conciliaciones bancarias</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Reportes mensuales</span>
              </div>
            </div>
            <a href="#contacto" class="inline-flex items-center gap-2 font-[Montserrat] text-[14px] font-semibold text-[#4CAF7A] hover:text-[#3d9466] transition-colors">
              Solicitar informaci&oacute;n
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        </div>

        <!-- Panel 2: Administrativo -->
        <div data-panel="2" class="srv-panel hidden">
          <div class="bg-white rounded-2xl border border-[#E2E8F0] p-8 lg:p-10">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-[52px] h-[52px] rounded-xl flex items-center justify-center bg-[#DBEAFE]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                  <path d="M3 9h18"></path>
                  <path d="M9 21V9"></path>
                </svg>
              </div>
              <h3 class="font-[Montserrat] text-[22px] font-bold text-[#2B2A5A]">Servicios Administrativos</h3>
            </div>
            <p class="font-['Open_Sans'] text-[15px] text-[#64748B] leading-relaxed mb-8">
              Optimizamos los procesos internos de tu empresa para que puedas enfocarte en lo que realmente importa: hacer crecer tu negocio con bases s&oacute;lidas.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">N&oacute;mina y seguridad social</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Costos y presupuestos</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Control de inventarios</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Flujo de efectivo</span>
              </div>
            </div>
            <a href="#contacto" class="inline-flex items-center gap-2 font-[Montserrat] text-[14px] font-semibold text-[#4CAF7A] hover:text-[#3d9466] transition-colors">
              Solicitar informaci&oacute;n
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        </div>

        <!-- Panel 3: Alianzas -->
        <div data-panel="3" class="srv-panel hidden">
          <div class="bg-white rounded-2xl border border-[#E2E8F0] p-8 lg:p-10">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-[52px] h-[52px] rounded-xl flex items-center justify-center bg-[#F3E8FF]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m11 17 2 2a1 1 0 1 0 3-3"></path>
                  <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"></path>
                  <path d="m21 3 1 11h-2"></path>
                  <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"></path>
                  <path d="M3 4h8"></path>
                </svg>
              </div>
              <h3 class="font-[Montserrat] text-[22px] font-bold text-[#2B2A5A]">Alianzas Estrat&eacute;gicas</h3>
            </div>
            <p class="font-['Open_Sans'] text-[15px] text-[#64748B] leading-relaxed mb-8">
              Colaboramos con especialistas en diversas &aacute;reas para ofrecerte soluciones complementarias que fortalezcan cada aspecto de tu empresa.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Asesor&iacute;a legal empresarial</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Seguros y fianzas</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Cr&eacute;ditos y financiamiento</span>
              </div>
              <div class="bg-[#F0FDF4] rounded-xl px-5 py-3.5 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-['Open_Sans'] text-[14px] text-[#2B2A5A] font-medium">Tecnolog&iacute;a y sistemas</span>
              </div>
            </div>
            <a href="#contacto" class="inline-flex items-center gap-2 font-[Montserrat] text-[14px] font-semibold text-[#4CAF7A] hover:text-[#3d9466] transition-colors">
              Solicitar informaci&oacute;n
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.srv-tab');
  const panels = document.querySelectorAll('.srv-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const index = tab.getAttribute('data-tab');

      // Reset all tabs
      tabs.forEach((t) => {
        t.classList.remove('srv-tab-active');
        t.classList.remove('bg-[#2B2A5A]', 'border-[#2B2A5A]');
        t.classList.add('bg-white', 'border-[#E2E8F0]');
        const title = t.querySelector('h3');
        const desc = t.querySelector('p');
        const iconBox = t.querySelector('div > div');
        if (title) title.classList.replace('text-white', 'text-[#2B2A5A]');
        if (desc) {
          desc.classList.remove('text-white/70');
          desc.classList.add('text-[#64748B]');
        }
      });

      // Activate clicked tab
      tab.classList.add('srv-tab-active');
      tab.classList.remove('bg-white', 'border-[#E2E8F0]');
      tab.classList.add('bg-[#2B2A5A]', 'border-[#2B2A5A]');
      const activeTitle = tab.querySelector('h3');
      const activeDesc = tab.querySelector('p');
      if (activeTitle) activeTitle.classList.replace('text-[#2B2A5A]', 'text-white');
      if (activeDesc) {
        activeDesc.classList.remove('text-[#64748B]');
        activeDesc.classList.add('text-white/70');
      }

      // Show corresponding panel
      panels.forEach((p) => p.classList.add('hidden'));
      const activePanel = document.querySelector(`[data-panel="${index}"]`);
      activePanel?.classList.remove('hidden');
    });
  });
