---
// CtaBand.astro – Call-to-action banner strip
---

<section
  class="w-full py-[48px] px-6 md:px-[80px]"
  style="background: linear-gradient(90deg, #2B2A5A 0%, #363473 100%);"
>
  <div class="max-w-[1440px] mx-auto flex flex-col lg:flex-row items-center justify-between gap-8">

    <!-- Left: Text -->
    <div class="text-center lg:text-left">
      <h2 class="text-white font-[Montserrat] text-[22px] md:text-[28px] font-bold leading-tight mb-2">
        &iquest;Listo para ordenar tus finanzas?
      </h2>
      <p class="text-white/70 text-[15px] md:text-base">
        Agenda una consulta gratuita y descubre cómo podemos impulsar tu empresa.
      </p>
    </div>

    <!-- Right: Buttons -->
    <div class="flex flex-col sm:flex-row items-center gap-3 shrink-0">
      <!-- Agendar Cita -->
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-[#F2C94C] hover:bg-[#E5BC3E] text-[#2B2A5A] font-[Montserrat] font-semibold text-[14px] px-6 py-3.5 rounded-xl transition-colors duration-300"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Agendar Cita Gratuita
      </a>

      <!-- WhatsApp -->
      <a
        href="https://wa.me/5255592023011"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366]/20 border border-[#25D366] text-[#25D366] hover:bg-[#25D366]/30 font-[Montserrat] font-semibold text-[14px] px-6 py-3.5 rounded-xl transition-colors duration-300"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        WhatsApp
      </a>
    </div>

  </div>
</section>
