---
// Diferenciadores.astro – ITA Contadores differentiators section
const cards = [
  {
    icon: "award",
    title: "14+ años impulsando negocios",
    desc: "Más de una década ayudando a empresas a crecer con solidez financiera y cumplimiento fiscal impecable.",
  },
  {
    icon: "zap",
    title: "Atención inmediata y personalizada",
    desc: "Respondemos en menos de 24 horas porque sabemos que tu tiempo y tus decisiones no pueden esperar.",
  },
  {
    icon: "target",
    title: "Estrategias a la medida",
    desc: "Cada negocio es único. Diseñamos planes contables y fiscales adaptados a tu industria y objetivos.",
  },
  {
    icon: "eye",
    title: "Visión financiera a largo plazo",
    desc: "No solo resolvemos el presente: te acompañamos con proyecciones y estrategias para un crecimiento sostenible.",
  },
];
---

<section
  class="w-full py-[80px] px-6 md:px-[120px]"
  style="background: linear-gradient(135deg, #2B2A5A 0%, #363473 100%);"
>
  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="inline-block font-[Montserrat] text-[12px] font-semibold text-[#4CAF7A] tracking-widest uppercase mb-3"
      >
        &iquest;Por qu&eacute; elegirnos?
      </span>
      <h2
        class="font-[Montserrat] text-[28px] md:text-[38px] font-bold italic text-white leading-tight mb-4"
      >
        Lo que nos hace diferentes
      </h2>
      <p class="font-[Open_Sans] text-[16px] text-white/70 max-w-[600px] mx-auto">
        Descubre las razones por las que nuestros clientes conf&iacute;an en nosotros para hacer crecer sus negocios.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {cards.map((card) => (
        <div class="flex flex-col items-center text-center">
          <!-- Icon Box -->
          <div class="w-[64px] h-[64px] rounded-2xl bg-white/10 flex items-center justify-center mb-5">
            {card.icon === "award" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="6"></circle>
                <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path>
              </svg>
            )}
            {card.icon === "zap" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
              </svg>
            )}
            {card.icon === "target" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="6"></circle>
                <circle cx="12" cy="12" r="2"></circle>
              </svg>
            )}
            {card.icon === "eye" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4CAF7A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            )}
          </div>

          <!-- Title -->
          <h3 class="font-[Montserrat] text-[16px] font-bold text-white mb-2">
            {card.title}
          </h3>

          <!-- Description -->
          <p class="font-[Open_Sans] text-[13px] text-white/50 leading-relaxed max-w-[240px]">
            {card.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
