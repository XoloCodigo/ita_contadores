---
// Footer.astro – ITA Contadores site footer
---

<footer class="w-full bg-[#1A1A40] pt-10 md:pt-[48px] pb-8 md:pb-[32px] px-6 md:px-16 lg:px-[80px]">
  <div class="max-w-[1440px] mx-auto">

    <!-- Top columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12 mb-12">

      <!-- Col 1: Brand -->
      <div>
        <h3 class="text-white font-heading font-bold text-[18px] mb-4">
          ITA CONTADORES<sup class="text-[10px]">&reg;</sup>
        </h3>
        <p class="text-gris-light text-[14px] leading-relaxed mb-6">
          Más que contabilidad: estrategia fiscal, cumplimiento y visión a futuro para tu negocio.
        </p>
        <!-- Social icons -->
        <div class="flex items-center gap-3">
          <!-- Facebook -->
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center hover:bg-white/[0.15] transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="#" aria-label="LinkedIn" class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center hover:bg-white/[0.15] transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center hover:bg-white/[0.15] transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a href="#" aria-label="WhatsApp" class="w-9 h-9 rounded-lg bg-white/[0.08] flex items-center justify-center hover:bg-white/[0.15] transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Servicios -->
      <div>
        <h4 class="text-white font-heading font-semibold text-[15px] mb-5">Servicios</h4>
        <ul class="flex flex-col gap-3">
          <li><a href="#servicios" class="text-gris-light text-[14px] hover:text-white transition-colors">Fiscal</a></li>
          <li><a href="#servicios" class="text-gris-light text-[14px] hover:text-white transition-colors">Contabilidad</a></li>
          <li><a href="#servicios" class="text-gris-light text-[14px] hover:text-white transition-colors">Administrativo</a></li>
          <li><a href="#servicios" class="text-gris-light text-[14px] hover:text-white transition-colors">Tecnología</a></li>
        </ul>
      </div>

      <!-- Col 3: Empresa -->
      <div>
        <h4 class="text-white font-heading font-semibold text-[15px] mb-5">Empresa</h4>
        <ul class="flex flex-col gap-3">
          <li><a href="#nosotros" class="text-gris-light text-[14px] hover:text-white transition-colors">Nosotros</a></li>
          <li><a href="#clientes" class="text-gris-light text-[14px] hover:text-white transition-colors">Clientes</a></li>
          <li><a href="#blog" class="text-gris-light text-[14px] hover:text-white transition-colors">Blog</a></li>
          <li><a href="#contacto" class="text-gris-light text-[14px] hover:text-white transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Col 4: Herramientas -->
      <div>
        <h4 class="text-white font-heading font-semibold text-[15px] mb-5">Herramientas</h4>
        <ul class="flex flex-col gap-3">
          <li><a href="#calculadora" class="text-gris-light text-[14px] hover:text-white transition-colors">Calculadora Fiscal</a></li>
          <li><a href="#diagnostico" class="text-gris-light text-[14px] hover:text-white transition-colors">Diagnóstico Fiscal</a></li>
          <li><a href="#portales" class="text-gris-light text-[14px] hover:text-white transition-colors">Portales Gobierno</a></li>
        </ul>
      </div>

    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-white/[0.1] mb-6"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[#64748B] text-[13px]">
        &copy; 2026 ITA Contadores. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacidad" class="text-gris-light text-[13px] hover:text-white transition-colors">Aviso de Privacidad</a>
        <a href="/terminos" class="text-gris-light text-[13px] hover:text-white transition-colors">T&eacute;rminos y Condiciones</a>
      </div>
    </div>

  </div>
</footer>
