---
// ClientLogos.astro – Infinite marquee of client logos
const logos = [
  "1.webp", "2.webp", "3.webp", "4.webp", "5.webp",
  "6.webp", "7.webp", "8.webp", "9.webp", "10.webp",
  "11.webp", "12.webp", "13.webp", "14.webp", "15.webp",
  "17.webp", "18.webp", "19.webp", "20.webp", "21.webp",
];
---

<section class="w-full bg-white py-12 px-6 md:px-20 overflow-hidden">
  <!-- Title -->
  <p
    class="text-center font-heading text-[12px] font-semibold tracking-widest text-gris-light mb-10 uppercase"
    aria-label="Empresas que confían en nosotros"
  >
    EMPRESAS QUE CONFÍAN EN NOSOTROS
  </p>

  <!-- Marquee wrapper -->
  <div class="relative w-full overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_5%,black_95%,transparent)]">
    <div class="marquee-track flex items-center gap-14 w-max">
      {/* First set */}
      {logos.map((file) => (
        <img
          src={`/images/clientes/${file}`}
          alt="Logo de empresa cliente"
          width="100"
          height="50"
          loading="eager"
          decoding="async"
          class="h-[50px] w-[100px] min-w-[100px] object-contain shrink-0"
        />
      ))}
      {/* Duplicate set for seamless loop */}
      {logos.map((file) => (
        <img
          src={`/images/clientes/${file}`}
          alt="Logo de empresa cliente"
          width="100"
          height="50"
          loading="eager"
          decoding="async"
          class="h-[50px] w-[100px] min-w-[100px] object-contain shrink-0"
        />
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee 30s linear infinite;
    will-change: transform;
  }

  @keyframes marquee {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>
