---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout title="P&aacute;gina no encontrada - ITA Contadores" description="La p&aacute;gina que buscas no existe.">
  <Navbar />
  <WhatsAppButton />

  <main class="pt-[100px] pb-20 px-6 md:px-16 lg:px-20 min-h-[60vh] flex items-center justify-center">
    <div class="max-w-lg mx-auto text-center">

      {/* 404 number */}
      <p class="font-heading text-[100px] md:text-[140px] font-bold text-azul/10 leading-none select-none">
        404
      </p>

      <h1 class="font-heading text-[24px] md:text-[32px] font-bold text-azul leading-tight -mt-6 mb-4">
        P&aacute;gina no encontrada
      </h1>
      <p class="text-gris text-[15px] font-body leading-relaxed mb-8">
        La p&aacute;gina que buscas no existe o fue movida. No te preocupes, puedes regresar al inicio o contactarnos si necesitas ayuda.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-verde text-white font-heading font-semibold text-[14px] rounded-xl px-6 py-3 hover:bg-verde/90 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Ir al inicio
        </a>
        <a
          href="/#contacto"
          class="inline-flex items-center gap-2 border border-border text-azul font-heading font-semibold text-[14px] rounded-xl px-6 py-3 hover:bg-gray-50 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          Cont&aacute;ctanos
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
